# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  Discord Bot 設定
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Discord Developer Portal で取得
# https://discord.com/developers/applications
DISCORD_TOKEN=your_discord_bot_token_here

# 管理者通知を送るチャンネルの ID（右クリック → IDをコピー）
ADMIN_CHANNEL_ID=123456789012345678

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  GitHub 設定
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# 招待先の GitHub 組織名（例: my-company）
GITHUB_ORG=your_github_org_name

# GitHub Personal Access Token
# 必要スコープ: admin:org（組織への招待に必要）
# https://github.com/settings/tokens
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  OAuth サーバー設定（Vercel / CF Workers）
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# GitHub OAuth App の設定
# https://github.com/settings/developers → OAuth Apps → New OAuth App
# Authorization callback URL: https://your-app.vercel.app/auth/callback
GITHUB_CLIENT_ID=your_github_oauth_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_client_secret

# デプロイした Vercel アプリの URL（末尾スラッシュなし）
OAUTH_SERVER_URL=https://your-app.vercel.app

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  Bot ↔ Webサーバー 間の Webhook 設定
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Bot が公開されている URL（Webhook 受信用）
# 例: Railway/Render でホストしている場合の URL
DISCORD_BOT_WEBHOOK=https://your-bot-host.railway.app

# Webhook 認証用シークレット（任意の長いランダム文字列）
# python -c "import secrets; print(secrets.token_urlsafe(32))" で生成
WEBHOOK_SECRET=your_random_webhook_secret_here

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  Bot サーバー設定
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Webhook 受信ポート（Railway 等は PORT 環境変数を自動設定）
WEBHOOK_PORT=8080

# SQLite DB ファイルパス（省略時: bot/data/bot.db）
# DB_PATH=/path/to/bot.db
